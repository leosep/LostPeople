@model List<PersonaReportada>
@{
    ViewData["Title"] = "Buscar persona";
    var total = (int)ViewBag.Total;
    var page = (int)ViewBag.Page;
    var totalPages = (int)ViewBag.TotalPages;
    var provincias = (List<ZonaGeografica>)ViewBag.Provincias;
}

<div class="max-w-7xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold text-primary mb-6">🔍 Buscar persona desaparecida</h1>

    <form method="get" action="/Buscar" class="bg-white p-6 rounded-lg shadow-sm border border-neutral-200 mb-8">
        <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-4">
            <div>
                <label class="block text-sm font-semibold mb-1" for="nombre">Nombre</label>
                <input type="text" id="nombre" name="nombre" value="@Context.Request.Query["nombre"]" placeholder="Nombre o apellido" class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" />
            </div>
            <div>
                <label class="block text-sm font-semibold mb-1" for="provinciaId">Provincia</label>
                <select id="provinciaId" name="provinciaId" class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary">
                    <option value="">Todas</option>
                    @foreach (var p in provincias)
                    {
                        <option value="@p.Id" selected="@(Context.Request.Query["provinciaId"] == p.Id.ToString())">@p.Nombre</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-sm font-semibold mb-1" for="estado">Estado</label>
                <select id="estado" name="estado" class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary">
                    <option value="">Todos</option>
                    <option value="RECIBIDO" selected="@(Context.Request.Query["estado"] == "RECIBIDO")">Desaparecido</option>
                    <option value="LOCALIZADO_VIVO" selected="@(Context.Request.Query["estado"] == "LOCALIZADO_VIVO")">Localizado</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-semibold mb-1" for="sexo">Sexo</label>
                <select id="sexo" name="sexo" class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary">
                    <option value="">Todos</option>
                    <option value="masculino" selected="@(Context.Request.Query["sexo"] == "masculino")">Masculino</option>
                    <option value="femenino" selected="@(Context.Request.Query["sexo"] == "femenino")">Femenino</option>
                </select>
            </div>
        </div>
        <div class="mt-4 flex justify-end">
            <button type="submit" class="px-8 py-3 bg-primary text-white font-bold rounded-lg hover:bg-primary-light transition min-h-[44px]">Buscar</button>
        </div>
    </form>

    @if (Model.Any())
    {
        <p class="text-neutral-600 mb-4">@total resultado(s) encontrado(s)</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            @foreach (var persona in Model)
            {
                <div class="bg-white rounded-lg shadow-sm border border-neutral-200 p-4 hover:shadow-md hover:border-primary-light transition">
                    <div class="flex items-start space-x-3">
                        <div class="w-20 h-20 bg-neutral-100 rounded-lg flex-shrink-0 flex items-center justify-center text-3xl">
                            @if (!string.IsNullOrEmpty(persona.FotoThumbnailUrl))
                            {
                                <img src="@persona.FotoThumbnailUrl" alt="Foto de @persona.PrimerNombre" class="w-full h-full rounded-lg object-cover" />
                            }
                            else { <span>👤</span> }
                        </div>
                        <div class="flex-1 min-w-0">
                            <h3 class="font-bold text-lg truncate">@persona.PrimerNombre @persona.PrimerApellido</h3>
                            <p class="text-sm text-neutral-500">@(persona.EdadAproximada?.ToString() ?? "?") años @(!string.IsNullOrEmpty(persona.Sexo) ? "· " + persona.Sexo : "")</p>
                            <p class="text-sm text-neutral-500">@persona.UltimaUbicacionZona?.Nombre</p>
                            <p class="text-xs text-neutral-400">@persona.FechaDesaparicion.ToString("dd/MM/yyyy")</p>
                            <span class="inline-block mt-2 px-2 py-1 text-xs font-bold rounded @(persona.EstadoCasoId <= 4 ? "bg-orange-100 text-orange-700" : "bg-green-100 text-green-700")">
                                @(persona.EstadoCasoId <= 4 ? "🟠 Desaparecido" : "✅ Localizado")
                            </span>
                        </div>
                    </div>
                    <div class="mt-3">
                        <a href="/Buscar/Detalle/@persona.Id" class="text-primary font-semibold text-sm hover:underline">Ver detalle →</a>
                    </div>
                </div>
            }
        </div>

        @if (totalPages > 1)
        {
            <div class="flex justify-center mt-8 space-x-2">
                @for (int i = 1; i <= totalPages; i++)
                {
                    <a href="@Url.Action("Index", new { nombre = Context.Request.Query["nombre"], provinciaId = Context.Request.Query["provinciaId"], estado = Context.Request.Query["estado"], sexo = Context.Request.Query["sexo"], page = i })"
                       class="px-4 py-2 rounded @(i == page ? "bg-primary text-white" : "bg-white border border-neutral-300 text-neutral-700 hover:bg-neutral-100")">
                        @i
                    </a>
                }
            </div>
        }
    }
    else if (Context.Request.Query.Any())
    {
        <div class="text-center py-12">
            <p class="text-xl text-neutral-600 mb-4">No encontramos personas con esos datos.</p>
            <p class="text-neutral-500 mb-6">¿Quieres intentar con otros filtros o <a href="/Reportar" class="text-primary font-semibold hover:underline">crear un reporte</a>?</p>
            <a href="/Buscar" class="text-primary hover:underline">Limpiar filtros</a>
        </div>
    }
    else
    {
        <div class="text-center py-12">
            <p class="text-lg text-neutral-500">Usa los filtros de arriba para buscar personas desaparecidas.</p>
        </div>
    }
</div>
