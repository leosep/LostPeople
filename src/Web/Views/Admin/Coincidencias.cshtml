@model List<Coincidencia>
@{
    ViewData["Title"] = "Coincidencias";
    var estadoActual = (string)ViewBag.EstadoActual;
}

<div class="max-w-6xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold text-primary mb-6">Coincidencias</h1>

    <div class="flex gap-2 mb-6">
        <a href="/Admin/Coincidencias?estado=Pendiente" class="px-4 py-2 rounded-lg text-sm font-semibold @(estadoActual == "Pendiente" ? "bg-yellow-500 text-white" : "bg-neutral-100 text-neutral-700 hover:bg-neutral-200")">Pendientes</a>
        <a href="/Admin/Coincidencias?estado=Confirmada" class="px-4 py-2 rounded-lg text-sm font-semibold @(estadoActual == "Confirmada" ? "bg-green-500 text-white" : "bg-neutral-100 text-neutral-700 hover:bg-neutral-200")">Confirmadas</a>
        <a href="/Admin/Coincidencias?estado=Rechazada" class="px-4 py-2 rounded-lg text-sm font-semibold @(estadoActual == "Rechazada" ? "bg-red-500 text-white" : "bg-neutral-100 text-neutral-700 hover:bg-neutral-200")">Rechazadas</a>
        <a href="/Admin/Coincidencias?estado=" class="px-4 py-2 rounded-lg text-sm font-semibold @(string.IsNullOrEmpty(estadoActual) ? "bg-primary text-white" : "bg-neutral-100 text-neutral-700 hover:bg-neutral-200")">Todas</a>
    </div>

    @if (TempData["Mensaje"] != null)
    {
        <div class="bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-lg mb-4">@TempData["Mensaje"]</div>
    }

    <div class="bg-white rounded-lg shadow-sm border border-neutral-200 overflow-hidden">
        @if (Model.Count == 0)
        {
            <div class="p-8 text-center text-neutral-500">
                <p class="text-lg font-semibold mb-2">No hay coincidencias @estadoActual.ToLower()</p>
                <p>Las coincidencias aparecerán aquí cuando el motor de matching las detecte.</p>
            </div>
        }
        else
        {
            <div class="divide-y divide-neutral-200">
                @foreach (var c in Model)
                {
                    <div class="p-4 hover:bg-neutral-50">
                        <div class="flex items-start justify-between">
                            <div>
                                <p class="font-semibold">@c.PersonaReportada?.PrimerNombre @c.PersonaReportada?.PrimerApellido</p>
                                <p class="text-sm text-neutral-500">Score: @(c.ScoreGeneral.ToString("P1"))</p>
                                <p class="text-xs text-neutral-400">Registro: @c.RegistroIngerido?.IdentificadorExterno (@c.FechaDeteccion.ToString("g"))</p>
                            </div>
                            <div class="flex gap-2">
                                @{
                                    var estadoLabel = c.Revisada ? (c.ResultadoRevision ?? "Revisada") : "Pendiente";
                                }
                                <span class="px-3 py-1 rounded-full text-xs font-semibold @(estadoLabel switch { "Pendiente" => "bg-yellow-100 text-yellow-800", "Confirmada" => "bg-green-100 text-green-800", "Rechazada" => "bg-red-100 text-red-800", _ => "bg-neutral-100" })">@estadoLabel</span>
                            </div>
                        </div>
                        @if (!c.Revisada)
                        {
                            <div class="mt-3 flex gap-2">
                                <form method="post" action="/Admin/RevisarCoincidencia">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@c.Id" />
                                    <input type="hidden" name="estado" value="Confirmada" />
                                    <button type="submit" class="px-4 py-2 bg-green-500 text-white rounded-lg text-sm hover:bg-green-600">Confirmar</button>
                                </form>
                                <form method="post" action="/Admin/RevisarCoincidencia">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@c.Id" />
                                    <input type="hidden" name="estado" value="Rechazada" />
                                    <button type="submit" class="px-4 py-2 bg-red-500 text-white rounded-lg text-sm hover:bg-red-600">Rechazar</button>
                                </form>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>
