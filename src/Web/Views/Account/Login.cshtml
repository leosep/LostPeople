@model LoginViewModel
@{
    ViewData["Title"] = "Iniciar sesión";
}

<div class="max-w-md mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-primary mb-2">Iniciar sesión</h1>
    <p class="text-neutral-600 mb-8">Accede a tu cuenta para dar seguimiento a tus casos.</p>

    @if (TempData["Mensaje"] != null)
    {
        <div class="bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-lg mb-4">@TempData["Mensaje"]</div>
    }

    <form method="post" class="bg-white p-6 rounded-lg shadow-sm border border-neutral-200 space-y-4">
        @Html.AntiForgeryToken()

        <div>
            <label class="block text-sm font-semibold mb-1" for="Email">Correo electrónico</label>
            <input type="email" id="Email" name="Email" required value="@Model.Email" class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" />
            @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-red-500 text-xs" })
        </div>

        <div>
            <label class="block text-sm font-semibold mb-1" for="Password">Contraseña</label>
            <input type="password" id="Password" name="Password" required class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" />
            @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-red-500 text-xs" })
        </div>

        <div class="flex items-center">
            <input type="checkbox" id="Recordarme" name="Recordarme" value="true" class="w-4 h-4 text-primary border-neutral-300 rounded focus:ring-primary" />
            <label for="Recordarme" class="ml-2 text-sm text-neutral-600">Recordarme</label>
        </div>

        @Html.ValidationSummary(true, "", new { @class = "text-red-500 text-sm" })

        <button type="submit" class="w-full px-6 py-3 bg-primary text-white font-bold rounded-lg hover:bg-primary-light transition min-h-[44px]">Iniciar sesión</button>
    </form>

    <p class="text-center text-sm text-neutral-500 mt-4">
        ¿No tienes cuenta? <a href="/Account/Register" class="text-primary hover:underline font-semibold">Regístrate aquí</a>
    </p>
</div>
