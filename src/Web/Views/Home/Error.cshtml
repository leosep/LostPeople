@{
    ViewData["Title"] = "Error";
}

<div class="max-w-2xl mx-auto px-4 py-16 text-center">
    <div class="w-20 h-20 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-6">
        <span class="text-4xl">⚠️</span>
    </div>
    <h1 class="text-3xl font-bold text-primary mb-4">Algo salió mal</h1>
    <p class="text-lg text-neutral-600 mb-8">Hubo un error al procesar tu solicitud. Por favor intenta de nuevo.</p>
    <a href="/" class="px-8 py-3 bg-primary text-white font-bold rounded-lg hover:bg-primary-light transition min-h-[44px]">Volver al inicio</a>
</div>
