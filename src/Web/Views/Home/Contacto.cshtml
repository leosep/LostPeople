@{
    ViewData["Title"] = "Contacto y autoridades";
}

<div class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-primary mb-6">Contacto y autoridades</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white p-6 rounded-lg shadow-sm border border-neutral-200">
            <h2 class="font-bold text-lg text-primary mb-2">🚔 Policía Nacional</h2>
            <p class="text-neutral-600 mb-2">Teléfono: <a href="tel:8095550100" class="text-primary font-semibold">809-555-0100</a></p>
            <a href="https://policianacional.gob.do" target="_blank" class="text-primary text-sm hover:underline">policianacional.gob.do</a>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-sm border border-neutral-200">
            <h2 class="font-bold text-lg text-primary mb-2">🆘 911 - Emergencias</h2>
            <p class="text-neutral-600 mb-2">Teléfono: <a href="tel:911" class="text-primary font-bold text-lg">911</a></p>
            <p class="text-sm text-neutral-500">Para emergencias inmediatas.</p>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-sm border border-neutral-200">
            <h2 class="font-bold text-lg text-primary mb-2">🔔 Alertas RD</h2>
            <p class="text-neutral-600 mb-2">Sistema Nacional de Alerta para Personas Desaparecidas</p>
            <p class="text-sm text-neutral-500">Creado por Ley 25-26.</p>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-sm border border-neutral-200">
            <h2 class="font-bold text-lg text-primary mb-2">📋 Asodofade</h2>
            <p class="text-neutral-600 mb-2">Asociación Dominicana de Familiares de Desaparecidos</p>
            <p class="text-sm text-neutral-500">Organización de la sociedad civil que apoya a familiares.</p>
        </div>
    </div>

    <div class="mt-8 bg-white p-6 rounded-lg shadow-sm border border-neutral-200">
        <h2 class="font-bold text-lg text-primary mb-3">Contacto del proyecto</h2>
        <p class="text-neutral-600">Si tienes preguntas sobre esta plataforma, contáctanos a través de los canales oficiales del gobierno dominicano.</p>
    </div>

    <div class="mt-6 p-4 bg-yellow-50 border border-yellow-200 rounded-lg">
        <p class="text-sm text-yellow-800 font-semibold">Recuerda: en caso de emergencia, llama al <a href="tel:911" class="underline font-bold">911</a>.</p>
    </div>
</div>
