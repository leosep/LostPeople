@model PersonaReportada
@{
    ViewData["Title"] = $"Estado - {Model.PrimerNombre} {Model.PrimerApellido}";
}

<div class="max-w-2xl mx-auto px-4 py-8">
    <h1 class="text-2xl font-bold text-primary mb-6">Estado del reporte</h1>

    <div class="bg-white rounded-lg shadow-sm border border-neutral-200 p-6 mb-6">
        <div class="text-center mb-6">
            <div class="w-24 h-24 bg-neutral-100 rounded-full flex items-center justify-center text-4xl mx-auto mb-4">
                @if (!string.IsNullOrEmpty(Model.FotoThumbnailUrl)) { <img src="@Model.FotoThumbnailUrl" alt="" class="w-full h-full rounded-full object-cover" /> }
                else { <span>👤</span> }
            </div>
            <h2 class="text-xl font-bold">@Model.PrimerNombre @Model.PrimerApellido</h2>
            <p class="text-neutral-500">Código: @Model.CodigoSeguimiento</p>
        </div>

        <div class="space-y-4">
            <div class="flex items-center space-x-3 p-3 bg-blue-50 rounded-lg">
                <span class="w-8 h-8 bg-blue-200 rounded-full flex items-center justify-center text-sm font-bold">1</span>
                <div>
                    <p class="font-semibold">Reporte recibido</p>
                    <p class="text-sm text-neutral-500">@Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</p>
                </div>
            </div>

            @if (Model.EstadoCasoId >= 2)
            {
                <div class="flex items-center space-x-3 p-3 bg-yellow-50 rounded-lg">
                    <span class="w-8 h-8 bg-yellow-200 rounded-full flex items-center justify-center text-sm font-bold">2</span>
                    <div>
                        <p class="font-semibold">En verificación</p>
                    </div>
                </div>
            }

            @if (Model.EstadoCasoId >= 3)
            {
                <div class="flex items-center space-x-3 p-3 bg-orange-50 rounded-lg">
                    <span class="w-8 h-8 bg-orange-200 rounded-full flex items-center justify-center text-sm font-bold">3</span>
                    <div>
                        <p class="font-semibold">Coincidencia detectada</p>
                    </div>
                </div>
            }

            @if (Model.EstadoCasoId >= 5)
            {
                <div class="flex items-center space-x-3 p-3 bg-green-50 rounded-lg">
                    <span class="w-8 h-8 bg-green-200 rounded-full flex items-center justify-center text-sm font-bold">✅</span>
                    <div>
                        <p class="font-semibold text-green-700">@Model.EstadoCaso?.Nombre</p>
                        @if (Model.FechaUltimaActualizacion.HasValue)
                        {
                            <p class="text-sm text-neutral-500">@Model.FechaUltimaActualizacion.Value.ToString("dd/MM/yyyy HH:mm")</p>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="text-center">
        <span class="inline-block px-4 py-2 rounded-full text-sm font-bold @(Model.EstadoCasoId <= 4 ? "bg-orange-100 text-orange-700" : "bg-green-100 text-green-700")">
            @(Model.EstadoCasoId <= 4 ? "🟠 " + (Model.EstadoCaso?.Nombre ?? "Desaparecido") : "✅ " + (Model.EstadoCaso?.Nombre ?? "Localizado"))
        </span>
    </div>

    @if (Model.EstadoCasoId <= 4)
    {
        <div class="mt-6 text-center">
            <a href="/Reportar/Localizada" class="text-primary font-semibold hover:underline">¿Ya apareció? Márcala como localizada</a>
        </div>
    }
</div>
