@model ReportarViewModel
@{
    ViewData["Title"] = "Reportar desaparición";
    var provincias = (List<ZonaGeografica>)ViewBag.Provincias;
}

<div class="max-w-2xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold text-primary mb-2">📢 Reportar una desaparición</h1>
    <p class="text-neutral-600 mb-8">Completa los datos de la persona desaparecida. Toda la información es confidencial.</p>

    <form method="post" action="/Reportar" enctype="multipart/form-data" class="bg-white p-6 rounded-lg shadow-sm border border-neutral-200 space-y-6">
        @Html.AntiForgeryToken()

        <div class="bg-blue-50 border-l-4 border-primary p-4 mb-6">
            <p class="text-sm text-primary font-semibold">Paso 1 de 3 — Datos de la persona</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-semibold mb-1" for="PrimerNombre">Primer nombre *</label>
                <input type="text" id="PrimerNombre" name="PrimerNombre" required value="@Model.PrimerNombre" class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" />
                @Html.ValidationMessageFor(m => m.PrimerNombre, "", new { @class = "text-red-500 text-xs" })
            </div>
            <div>
                <label class="block text-sm font-semibold mb-1" for="SegundoNombre">Segundo nombre</label>
                <input type="text" id="SegundoNombre" name="SegundoNombre" value="@Model.SegundoNombre" class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" />
            </div>
            <div>
                <label class="block text-sm font-semibold mb-1" for="PrimerApellido">Primer apellido *</label>
                <input type="text" id="PrimerApellido" name="PrimerApellido" required value="@Model.PrimerApellido" class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" />
                @Html.ValidationMessageFor(m => m.PrimerApellido, "", new { @class = "text-red-500 text-xs" })
            </div>
            <div>
                <label class="block text-sm font-semibold mb-1" for="SegundoApellido">Segundo apellido</label>
                <input type="text" id="SegundoApellido" name="SegundoApellido" value="@Model.SegundoApellido" class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" />
            </div>
            <div>
                <label class="block text-sm font-semibold mb-1" for="Alias">Alias / apodo</label>
                <input type="text" id="Alias" name="Alias" value="@Model.Alias" class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" />
            </div>
            <div>
                <label class="block text-sm font-semibold mb-1" for="FotoPersona">Foto de la persona</label>
                <input type="file" id="FotoPersona" name="FotoPersona" accept="image/*" class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary" />
                <p class="text-xs text-neutral-500 mt-1">Opcional. Formatos: JPG, PNG. Máximo 5MB.</p>
            </div>
        </div>

        <hr class="border-neutral-200" />

        <div>
            <label class="block text-sm font-semibold mb-1">¿Qué edad tiene?</label>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs text-neutral-500 mb-1" for="EdadAproximada">Edad aproximada</label>
                    <input type="number" id="EdadAproximada" name="EdadAproximada" value="@Model.EdadAproximada" class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary" />
                </div>
                <div>
                    <label class="block text-xs text-neutral-500 mb-1" for="Sexo">Sexo</label>
                    <select id="Sexo" name="Sexo" class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary">
                        <option value="">Seleccionar</option>
                        <option value="Masculino">Masculino</option>
                        <option value="Femenino">Femenino</option>
                    </select>
                </div>
            </div>
        </div>

        <hr class="border-neutral-200" />

        <div>
            <label class="block text-sm font-semibold mb-1">¿Dónde se le vio por última vez?</label>
            <div class="space-y-3">
                <div>
                    <label class="block text-xs text-neutral-500 mb-1" for="UltimaUbicacionTexto">Lugar</label>
                    <input type="text" id="UltimaUbicacionTexto" name="UltimaUbicacionTexto" value="@Model.UltimaUbicacionTexto" placeholder="Ej: Av. 27 de Febrero, frente a Acrópolis" class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary" />
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs text-neutral-500 mb-1" for="UltimaUbicacionZonaId">Provincia</label>
                        <select id="UltimaUbicacionZonaId" name="UltimaUbicacionZonaId" class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary">
                            <option value="">Seleccionar</option>
                            @foreach (var p in provincias)
                            {
                                <option value="@p.Id">@p.Nombre</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs text-neutral-500 mb-1" for="FechaDesaparicion">Fecha de desaparición</label>
                        <input type="date" id="FechaDesaparicion" name="FechaDesaparicion" value="@Model.FechaDesaparicion?.ToString("yyyy-MM-dd")" class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary" />
                    </div>
                </div>
            </div>
        </div>

        <hr class="border-neutral-200" />

        <div>
            <label class="block text-sm font-semibold mb-1">Descripción física (opcional)</label>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                <div>
                    <label class="block text-xs text-neutral-500 mb-1" for="EstaturaCm">Estatura (cm)</label>
                    <input type="number" id="EstaturaCm" name="EstaturaCm" value="@Model.EstaturaCm" placeholder="170" class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary" />
                </div>
                <div>
                    <label class="block text-xs text-neutral-500 mb-1" for="ColorPiel">Color de piel</label>
                    <input type="text" id="ColorPiel" name="ColorPiel" value="@Model.ColorPiel" placeholder="Moreno" class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary" />
                </div>
                <div>
                    <label class="block text-xs text-neutral-500 mb-1" for="ColorCabello">Color de cabello</label>
                    <input type="text" id="ColorCabello" name="ColorCabello" value="@Model.ColorCabello" placeholder="Negro" class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary" />
                </div>
                <div>
                    <label class="block text-xs text-neutral-500 mb-1" for="ColorOjos">Color de ojos</label>
                    <input type="text" id="ColorOjos" name="ColorOjos" value="@Model.ColorOjos" placeholder="Marrón" class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary" />
                </div>
            </div>
            <div class="mt-3">
                <label class="block text-xs text-neutral-500 mb-1" for="SenasParticulares">Señas particulares (tatuajes, cicatrices)</label>
                <textarea id="SenasParticulares" name="SenasParticulares" rows="2" class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary">@Model.SenasParticulares</textarea>
            </div>
            <div class="mt-3">
                <label class="block text-xs text-neutral-500 mb-1" for="Vestimenta">Vestimenta que llevaba</label>
                <input type="text" id="Vestimenta" name="Vestimenta" value="@Model.Vestimenta" placeholder="Camisa azul, jeans, tenis blancos" class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary" />
            </div>
            <div class="mt-3">
                <label class="block text-xs text-neutral-500 mb-1" for="CondicionMedica">Condición médica (opcional — solo lo verán las autoridades) 🔒</label>
                <input type="text" id="CondicionMedica" name="CondicionMedica" value="@Model.CondicionMedica" placeholder="Ej: Diabetes tipo 2" class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary" />
            </div>
        </div>

        <hr class="border-neutral-200" />

        <div class="bg-blue-50 border-l-4 border-primary p-4">
            <p class="text-sm text-primary font-semibold">Paso 2 de 3 — Tus datos de contacto</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-semibold mb-1" for="RelacionConDesaparecido">Relación con la persona</label>
                <select id="RelacionConDesaparecido" name="RelacionConDesaparecido" class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary">
                    <option value="">Seleccionar</option>
                    <option value="Madre/Padre">Madre/Padre</option>
                    <option value="Hijo/a">Hijo/a</option>
                    <option value="Hermano/a">Hermano/a</option>
                    <option value="Cónyuge">Cónyuge</option>
                    <option value="Familiar">Otro familiar</option>
                    <option value="Amigo/a">Amigo/a</option>
                    <option value="Conocido">Conocido</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-semibold mb-1" for="TelefonoContacto">Teléfono de contacto *</label>
                <input type="tel" id="TelefonoContacto" name="TelefonoContacto" required value="@Model.TelefonoContacto" placeholder="809-000-0000" class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary" />
                @Html.ValidationMessageFor(m => m.TelefonoContacto, "", new { @class = "text-red-500 text-xs" })
            </div>
            <div>
                <label class="block text-sm font-semibold mb-1" for="EmailContacto">Correo electrónico</label>
                <input type="email" id="EmailContacto" name="EmailContacto" value="@Model.EmailContacto" placeholder="correo@ejemplo.com" class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary" />
            </div>
        </div>

        <hr class="border-neutral-200" />

        <div class="bg-blue-50 border-l-4 border-primary p-4">
            <p class="text-sm text-primary font-semibold">Paso 3 de 3 — Confirma</p>
        </div>

        <div class="space-y-3">
            <label class="flex items-start space-x-3">
                <input type="checkbox" name="AceptoTerminos" value="true" class="mt-1 w-5 h-5 text-primary border-neutral-300 rounded focus:ring-primary" />
                <span class="text-sm text-neutral-600">Acepto los <a href="/Home/Privacy" class="text-primary hover:underline">términos y condiciones</a> y la política de protección de datos (Ley 172-13).</span>
            </label>
            @Html.ValidationMessageFor(m => m.AceptoTerminos, "", new { @class = "text-red-500 text-xs" })
            <label class="flex items-start space-x-3">
                <input type="checkbox" name="AceptoConfidencialidad" value="true" class="mt-1 w-5 h-5 text-primary border-neutral-300 rounded focus:ring-primary" />
                <span class="text-sm text-neutral-600">Entiendo que esto <strong>no reemplaza</strong> una denuncia policial. Si es una emergencia, llamaré al 911.</span>
            </label>
            @Html.ValidationMessageFor(m => m.AceptoConfidencialidad, "", new { @class = "text-red-500 text-xs" })
        </div>

        <div class="flex justify-end">
            <button type="submit" class="px-8 py-4 bg-primary text-white font-bold rounded-lg hover:bg-primary-light transition text-lg min-h-[44px]">Enviar reporte</button>
        </div>
    </form>

    <div class="mt-6 p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-center">
        <p class="text-sm text-yellow-800">⚠️ Recuerda: si es una emergencia, llama al <a href="tel:911" class="font-bold underline">911</a>.</p>
    </div>
</div>