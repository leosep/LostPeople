@{
    ViewData["Title"] = "Reporte recibido";
    var codigo = TempData["CodigoSeguimiento"] as string;
    var nombre = TempData["PersonaNombre"] as string;
}

<div class="max-w-2xl mx-auto px-4 py-16 text-center">
    <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
        <span class="text-4xl">✅</span>
    </div>

    <h1 class="text-3xl font-bold text-primary mb-4">Reporte recibido</h1>
    <p class="text-lg text-neutral-600 mb-6">Hemos recibido tu reporte de <strong>@nombre</strong>.</p>

    <div class="bg-white p-8 rounded-lg shadow-sm border border-neutral-200 mb-8 inline-block">
        <p class="text-sm text-neutral-500 mb-2">Tu código de seguimiento es:</p>
        <p class="text-3xl font-bold text-primary tracking-widest">@codigo</p>
        <p class="text-xs text-neutral-400 mt-2">Guarda este código para dar seguimiento a tu reporte.</p>
    </div>

    <p class="text-neutral-600 mb-6">📱 Te enviaremos un SMS cuando haya novedades.</p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/Reportar/Localizada" class="px-6 py-3 bg-accent text-white font-bold rounded-lg hover:bg-accent-light transition min-h-[44px]">Marca como localizada</a>
        <a href="/Reportar/Seguimiento" class="px-6 py-3 bg-primary text-white font-bold rounded-lg hover:bg-primary-light transition min-h-[44px]">Dar seguimiento</a>
    </div>

    <div class="mt-8">
        <a href="/" class="text-primary font-semibold hover:underline">← Volver al inicio</a>
    </div>

    <div class="mt-6 p-4 bg-yellow-50 border border-yellow-200 rounded-lg inline-block">
        <p class="text-sm text-yellow-800">Recuerda: si es una emergencia, llama al <strong>911</strong>.</p>
    </div>
</div>
