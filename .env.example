# =============================================================================
# LostPeople RD - Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in values, or set these as system/IIS env vars.
# In IIS, set these in web.config <environmentVariables> or IIS Manager > Configuration Editor.

# --- Database (SQL Server) ---
# Connection string takes highest priority. If empty, individual values below are used.
ConnectionStrings__DefaultConnection=
LOSTPEOPLE_DB_SERVER=sql.rsite.net\MSSQL2022
LOSTPEOPLE_DB_NAME=leosep_People
LOSTPEOPLE_DB_USER=
LOSTPEOPLE_DB_PASSWORD=

# --- Twilio (SMS) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- SMTP (Email) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@lostpeople.do

# --- Seq (Structured Logging) ---
SEQ_URL=

# --- SSL / Proxy (shared hosting) ---
# Set to "https" when SSL is terminated upstream (e.g., by IIS ARR / load balancer).
# When set, the app will trust forwarded headers from the proxy.
FORWARDED_SCHEME=https

# --- ASP.NET Core ---
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://localhost:5000
